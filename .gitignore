# Entorno virtual y dependencias
venv/
.venv/
env/
ENV/

# Archivos de configuración y credenciales (¡CRÍTICO!)
# Nota: .env.example SÍ se versiona (plantilla sin secretos).
.env
.env.local
.env.*.local

# Caché de Python
**/__pycache__/
*.py[cod]
*$py.class

# Directorios específicos del proyecto que contienen datos locales o caché
.claude/
chat_uploads/
data/
workspaces/

# IDEs y editores de texto
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Logs y archivos temporales
*.log
*.tmp
.agents/

# Scripts de depuración temporales (no versionar)
_test_*.py
_debug*.py
