# ─── T.H.E.M.I.S. — Variables de entorno ──────────────────────────────────────
# Copia este archivo a `.env` y rellena tus claves. `.env` está en .gitignore
# y NUNCA debe subirse al repositorio.

# ── Núcleo (Anthropic / Claude) — REQUERIDO ──────────────────────────────────
# Los modelos de Anthropic se activan con EMERGENT_LLM_KEY o ANTHROPIC_API_KEY.
# Si defines ANTHROPIC_API_KEY, la app la usa automáticamente como EMERGENT_LLM_KEY.
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (modelos GPT + generación de imágenes) — OPCIONAL ─────────────────
# Sin esta clave, los modelos GPT y la generación de imágenes no funcionan,
# pero Claude sigue operando con normalidad.
OPENAI_API_KEY=sk-proj-...

# ── DeepSeek (modelos deepseek-v4-*) — OPCIONAL ──────────────────────────────
DEEPSEEK_API_KEY=sk-...

# ── NewsAPI.org (feed de Noticias + carrusel del pop-up) — OPCIONAL ──────────
# Consíguela gratis en https://newsapi.org
NEWS_API=...

# ── Fish Audio (voz TTS de J.A.R.V.I.S. para leer titulares) — OPCIONAL ──────
# Requiere crédito de API en https://fish.audio/app/developers
FISH_API_KEY=...

# ── Configuración del servidor — OPCIONAL (valores por defecto) ──────────────
# HOST=0.0.0.0
# PORT=8001
# RELOAD=1
